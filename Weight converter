weight =float(input("enter your weight: "))
unit = input("kg or lbs? ")

if unit=='kg':
    weight*=2.205
    unit = 'lbs'
    print(f"your weight is {round(weight,1)} {unit}")
elif unit=='lbs':
    weight /=2.205
    unit = 'kg'
    print(f"your weight is {round(weight,1)} {unit}")
else:
    print(f"{unit} was not valid, please enter either kg or lbs")


